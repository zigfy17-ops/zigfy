{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "includeFiles": ["dist/client/**", "dist/server/**"]
    }
  },
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/api"
    }
  ]
}
